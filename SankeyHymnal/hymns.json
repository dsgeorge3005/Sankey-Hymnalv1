<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sankey Hymnal — Liquid Glass Edition</title>

    <style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.45);
        --glass-border: rgba(255, 255, 255, 0.4);
        --glass-shadow: rgba(31, 38, 135, 0.08);
        --text-color: #1d1d1f;
        --accent-color: #007aff;
        --accent-glow: rgba(0, 122, 255, 0.3);
        --bg-gradient: linear-gradient(135deg, #e0eafc 0%, #cfdef3 100%);
    }

    .dark-mode {
        --glass-bg: rgba(28, 28, 30, 0.45);
        --glass-border: rgba(255, 255, 255, 0.08);
        --glass-shadow: rgba(0, 0, 0, 0.4);
        --text-color: #f5f5f7;
        --accent-color: #0a84ff;
        --accent-glow: rgba(10, 132, 255, 0.4);
        --bg-gradient: linear-gradient(135deg, #141e30 0%, #243b55 100%);
    }

    * { box-sizing: border-box; }

    body {
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, sans-serif;
        background: var(--bg-gradient);
        background-attachment: fixed;
        color: var(--text-color);
        margin: 0;
        padding: 20px;
        min-height: 100vh;
        transition: background 0.4s ease, color 0.3s ease;
        overflow-x: hidden;
    }

    /* LIQUID GLASS CONTAINER MOP-UP */
    .glass-panel {
        background: var(--glass-bg);
        backdrop-filter: blur(20px) saturate(190%);
        -webkit-backdrop-filter: blur(20px) saturate(190%);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        box-shadow: 0 8px 32px 0 var(--glass-shadow);
        padding: 24px;
        transition: transform 0.3s ease, background 0.3s ease;
    }

    .container {
        max-width: 900px;
        margin: auto;
        display: flex;
        flex-direction: column;
        gap: 20px;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
    }

    body.drawer-open .container {
        transform: translateX(-180px);
        opacity: 0.4;
    }

    h1 {
        text-align: center;
        font-size: 40px;
        font-weight: 800;
        letter-spacing: -1px;
        margin: 10px 0;
        background: linear-gradient(90deg, #007aff, #00c6ff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .search-bar {
        display: flex;
        gap: 12px;
    }

    input, select {
        flex: 1;
        padding: 16px 20px;
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        font-size: 16px;
        background: rgba(255, 255, 255, 0.25);
        color: var(--text-color);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        font-family: inherit;
        outline: none;
        transition: all 0.2s ease;
    }
    .dark-mode input, .dark-mode select {
        background: rgba(0, 0, 0, 0.2);
    }

    input:focus, select:focus {
        border-color: var(--accent-color);
        box-shadow: 0 0 0 4px var(--accent-glow);
    }

    button {
        background: var(--accent-color);
        color: white;
        border: none;
        padding: 14px 24px;
        border-radius: 16px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 600;
        backdrop-filter: blur(5px);
        box-shadow: 0 4px 15px var(--accent-glow);
        transition: all 0.2s ease;
        white-space: nowrap;
    }

    button:hover {
        transform: translateY(-2px);
        opacity: 0.95;
    }
    button:active { transform: translateY(0); }

    button:disabled {
        background: rgba(142, 142, 147, 0.3) !important;
        color: rgba(0,0,0,0.3) !important;
        cursor: not-allowed;
        box-shadow: none !important;
        transform: none !important;
    }
    .dark-mode button:disabled { color: rgba(255,255,255,0.3) !important; }

    /* SUGGESTIONS PANEL */
    #suggestions {
        border-radius: 18px;
        overflow: hidden;
        margin-top: -8px;
        display: none;
        flex-direction: column;
    }
    .suggestion {
        padding: 14px 20px;
        cursor: pointer;
        border-bottom: 1px solid var(--glass-border);
        transition: background 0.2s ease;
    }
    .suggestion:hover, .suggestion.selected {
        background: rgba(255, 255, 255, 0.35);
    }
    .dark-mode .suggestion:hover, .dark-mode .suggestion.selected {
        background: rgba(255, 255, 255, 0.1);
    }

    /* SETLIST MANAGER */
    .dashboard-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .dashboard-content.open { max-height: 800px; }

    .setlist-controls {
        display: flex;
        gap: 12px;
        align-items: flex-end;
        flex-wrap: wrap;
        margin-bottom: 15px;
    }
    .control-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
        min-width: 140px;
    }
    .control-group label {
        font-size: 13px;
        font-weight: 700;
        opacity: 0.8;
    }

    .setlist-pill-box { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 15px; }
    .setlist-pill {
        background: rgba(255,255,255,0.3);
        border: 1px solid var(--glass-border);
        padding: 8px 16px;
        border-radius: 30px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-weight: 600;
        cursor: pointer;
    }
    .dark-mode .setlist-pill { background: rgba(0,0,0,0.25); }
    .setlist-pill .remove-btn { color: #ff3b30; font-weight: bold; margin-left: 4px; }

    /* SATB TRACKS AUDIO SECTION */
    .audio-section { margin-top: 25px; }
    .audio-section h3 { margin: 0 0 15px 0; font-size: 18px; font-weight: 700; }
    .audio-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 15px; }
    .audio-card {
        background: rgba(255, 255, 255, 0.2);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 15px;
    }
    .dark-mode .audio-card { background: rgba(0,0,0,0.15); }
    .voice-part { font-weight: 700; font-size: 15px; margin-bottom: 8px; color: var(--accent-color); }
    audio { width: 100%; height: 36px; outline: none; }

    /* SCORE VIEWER IMAGES */
    img { width: 100%; height: auto; border-radius: 16px; margin-top: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); }

    /* SIDE MUSIC TOOLKIT DRAWER */
    .side-drawer {
        position: fixed;
        top: 0;
        right: -390px;
        width: 360px;
        height: 100%;
        z-index: 1000;
        transition: right 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        padding: 24px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 25px;
    }
    .side-drawer.open { right: 0; }
    .drawer-header { display: flex; justify-content: space-between; align-items: center; }
    
    /* PIANO ENGINE */
    .piano { display: flex; position: relative; height: 130px; background: #111; padding: 3px; border-radius: 12px; box-shadow: inset 0 0 10px rgba(0,0,0,0.8); }
    .white-key { flex: 1; background: linear-gradient(to bottom, #fff 0%, #ebebeb 100%); border: 1px solid #bbb; border-radius: 0 0 6px 6px; cursor: pointer; z-index: 1; }
    .white-key:active { background: #dcdcdc; }
    .black-key { position: absolute; width: 6.5%; height: 60%; background: linear-gradient(to bottom, #333 0%, #000 100%); border-radius: 0 0 4px 4px; cursor: pointer; z-index: 2; transform: translateX(-50%); }
    .black-key:active { background: #222; }

    /* METRONOME */
    .metro-display { display: flex; justify-content: space-between; font-weight: 700; }
    .metro-visuals { display: flex; justify-content: center; gap: 8px; margin: 10px 0; }
    .metro-dot { width: 12px; height: 12px; background: rgba(0,0,0,0.15); border-radius: 50%; transition: background 0.1s transform 0.1s; }
    .dark-mode .metro-dot { background: rgba(255,255,255,0.2); }
    .metro-dot.active { background: #ff3b30; transform: scale(1.3); box-shadow: 0 0 8px #ff3b30; }

    .glossary-box { max-height: 200px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; }
    .term-item { border-bottom: 1px solid var(--glass-border); padding-bottom: 8px; }
    .term-name { font-weight: 700; }
    .term-def { font-size: 14px; opacity: 0.7; margin-top: 2px; }

    @media (max-width: 600px) {
        h1 { font-size: 32px; }
        body.drawer-open .container { transform: translateX(-280px); opacity: 0.1; }
        .side-drawer { width: 300px; right: -330px; }
    }
    </style>
</head>
<body>

<div id="musicalDrawer" class="side-drawer glass-panel">
    <div class="drawer-header">
        <h2 style="margin:0; font-size:22px;">🎼 Musician Toolkit</h2>
        <button onclick="toggleDrawer()" style="padding: 8px 14px; font-size:13px;">✕ Close</button>
    </div>

    <div style="display:flex; flex-direction:column; gap:12px;">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <button onclick="shiftOctave(-1)">◀ Octave</button>
            <span id="octaveDisplay" style="font-weight:bold;">Octave: 4</span>
            <button onclick="shiftOctave(1)">Octave ▶</button>
        </div>
        <div class="piano" id="pianoLayout">
            <div class="white-key" onclick="playTone('C')"></div>
            <div class="white-key" onclick="playTone('D')"></div>
            <div class="white-key" onclick="playTone('E')"></div>
            <div class="white-key" onclick="playTone('F')"></div>
            <div class="white-key" onclick="playTone('G')"></div>
            <div class="white-key" onclick="playTone('A')"></div>
            <div class="white-key" onclick="playTone('B')"></div>
            <div class="white-key" onclick="playTone('C2')"></div>
            <div class="black-key" style="left: 12.5%;" onclick="playTone('C#')"></div>
            <div class="black-key" style="left: 26.5%;" onclick="playTone('D#')"></div>
            <div class="black-key" style="left: 53.5%;" onclick="playTone('F#')"></div>
            <div class="black-key" style="left: 67.5%;" onclick="playTone('G#')"></div>
            <div class="black-key" style="left: 81.5%;" onclick="playTone('A#')"></div>
        </div>
    </div>

    <div style="display:flex; flex-direction:column; gap:12px;">
        <div class="metro-display">
            <span>Metronome</span>
            <span id="bpmDisplay">100 BPM</span>
        </div>
        <input type="range" id="tempoSlider" min="40" max="220" value="100" oninput="updateBpm(this.value)" style="width:100%;">
        <select id="timeSignatureSelect" onchange="updateTimeSignature(this.value)">
            <option value="4">4/4 Common Time</option>
            <option value="3">3/4 Waltz Meter</option>
            <option value="2">2/4 March Meter</option>
            <option value="6">6/8 Compound Duple</option>
        </select>
        <div class="metro-visuals" id="metroVisualsContainer"></div>
        <button id="metroBtn" onclick="toggleMetronome()" style="width:100%;">▶ Start</button>
    </div>

    <div>
        <h3 style="margin:0 0 10px 0;">📚 Dictionary</h3>
        <div class="glossary-box" id="glossaryList"></div>
    </div>
</div>

<div class="container">
    <div style="display:flex; justify-content:space-between; align-items:center;">
        <button onclick="toggleDashboard()">📂 Setlist Builder</button>
        <div style="display:flex; gap:10px;">
            <button onclick="toggleDrawer()" style="background:var(--accent-color);">🎵 Tools</button>
            <button onclick="toggleTheme()" style="background:rgba(120,120,120,0.2); color:var(--text-color); box-shadow:none;">🌓 Theme</button>
        </div>
    </div>

    <div id="weeklyDashboard" class="dashboard-content">
        <div class="glass-panel">
            <h3 style="margin:0 0 15px 0;">📋 Service Setlist Manager</h3>
            <div class="setlist-controls">
                <div class="control-group">
                    <label>Target Configuration</label>
                    <select id="setlistNumSelect" onchange="renderActiveSetlistPills()">
                        <option value="1">Service Set 1</option>
                        <option value="2">Service Set 2</option>
                        <option value="3">Service Set 3</option>
                    </select>
                </div>
                <div class="control-group" style="flex:1.2; flex-direction:row; align-items:flex-end; gap:8px;">
                    <div style="flex:1; display:flex; flex-direction:column; gap:6px;">
                        <label>Quick Add Hymn #</label>
                        <input type="number" id="quickAddHymnNum" placeholder="e.g. 1">
                    </div>
                    <button onclick="addHymnToActiveSetlist()" style="height:52px;">+ Add</button>
                </div>
            </div>
            <div class="setlist-pill-box" id="activeSetlistContainer"></div>
        </div>
    </div>

    <h1>Sankey Hymnal</h1>

    <div class="search-bar">
        <input id="searchBox" placeholder="Enter hymn title or selection number..." autocomplete="off">
        <button onclick="searchHymn()">Search</button>
    </div>
    
    <div id="suggestions" class="glass-panel"></div>
    <div id="results"></div>
    <div id="scoreViewer"></div>
</div>

<script>
// RAW HYMNS DATABASE EMBEDDED TO STOP ROUTING FAILURES
const localHymnsDataset = [
  { "number": "1", "title": "Praise, My Soul, The King Of Heaven!", "page": "1" },
  { "number": "10", "title": "Day by Day the manna fell", "page": "10" },
  { "number": "11", "title": "Oh, Worship the King", "page": "11" },
  { "number": "102", "title": "Hallelujah What a Savior", "page": "102" },
  { "number": "111", "title": "Joy to the World", "page": "111" },
  { "number": "112", "title": "How Sweet the Name", "page": "112" },
  { "number": "113", "title": "Blessed Be the Fountain", "page": "113" },
  { "number": "1084", "title": "Jesus shall reign", "page": "1084" },
  { "number": "1131", "title": "Tell me the Old, Old Story", "page": "1131" },
  { "number": "1134", "title": "There is a Green Hill Far Away (2nd tune)", "page": "1134" }
];

const glossaryTerms = [
    { name: "4/4 Time", def: "4 beats per measure. Each quarter note gets 1 count pulse." },
    { name: "3/4 Time", def: "3 beats per measure. Used heavily in historic hymns and waltzes." },
    { name: "A Cappella", def: "Vocal music performed entirely without instrumental backing tracks." },
    { name: "Fermata", def: "Hold or sustain the note until cut off by the ensemble director." }
];

/* LOCAL SYNTH AUDIO ENGINE */
const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
let activeOctave = 4;
const baseFrequencies = { 'C':16.35, 'C#':17.32, 'D':18.35, 'D#':19.45, 'E':20.60, 'F':21.83, 'F#':23.12, 'G':24.50, 'G#':25.96, 'A':27.50, 'A#':29.14, 'B':30.87, 'C2':32.70 };

function playTone(note) {
    let fundamental = baseFrequencies[note] * Math.pow(2, activeOctave);
    let now = audioCtx.currentTime;
    let masterGain = audioCtx.createGain();
    masterGain.connect(audioCtx.destination);
    masterGain.gain.setValueAtTime(0, now);
    masterGain.gain.linearRampToValueAtTime(0.25, now + 0.01);
    masterGain.gain.exponentialRampToValueAtTime(0.001, now + 1.2);

    let osc = audioCtx.createOscillator();
    osc.type = 'triangle';
    osc.frequency.setValueAtTime(fundamental, now);
    osc.connect(masterGain);
    osc.start(now); osc.stop(now + 1.2);
}
function shiftOctave(dir) { activeOctave = Math.max(2, Math.min(6, activeOctave + dir)); document.getElementById("octaveDisplay").innerText = "Octave: " + activeOctave; }
function toggleDrawer() { document.getElementById("musicalDrawer").classList.toggle("open"); document.body.classList.toggle("drawer-open", document.getElementById("musicalDrawer").classList.contains("open")); }

/* METRONOME LOGIC */
let metroInterval = null, isMetroRunning = false, bpm = 100, currentBeat = 0, beatsPerMeasure = 4;
function updateBpm(val) { bpm = val; document.getElementById("bpmDisplay").innerText = val + " BPM"; if (isMetroRunning) { stopMetronome(); startMetronome(); } }
function updateTimeSignature(val) { beatsPerMeasure = parseInt(val); currentBeat = 0; let html = ""; for(let i=0; i<beatsPerMeasure; i++) html += `<div class="metro-dot" id="dotM${i}"></div>`; document.getElementById("metroVisualsContainer").innerHTML = html; if (isMetroRunning) { stopMetronome(); startMetronome(); } }
function toggleMetronome() { if (isMetroRunning) stopMetronome(); else startMetronome(); }
function startMetronome() {
    isMetroRunning = true; document.getElementById("metroBtn").innerText = "⏹ Stop"; document.getElementById("metroBtn").style.background = "#ff3b30";
    metroInterval = setInterval(() => {
        for(let i=0; i<beatsPerMeasure; i++) document.getElementById(`dotM${i}`)?.classList.remove('active');
        document.getElementById(`dotM${currentBeat}`)?.classList.add('active');
        let osc = audioCtx.createOscillator(); let gain = audioCtx.createGain();
        osc.frequency.setValueAtTime(currentBeat === 0 ? 1000 : 600, audioCtx.currentTime);
        gain.gain.setValueAtTime(0.15, audioCtx.currentTime); gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.05);
        osc.connect(gain); gain.connect(audioCtx.destination); osc.start(); osc.stop(audioCtx.currentTime + 0.06);
        currentBeat = (currentBeat + 1) % beatsPerMeasure;
    }, (60 / bpm) * 1000);
}
function stopMetronome() { isMetroRunning = false; clearInterval(metroInterval); document.getElementById("metroBtn").innerText = "▶ Start"; document.getElementById("metroBtn").style.background = ""; currentBeat = 0; }

/* LOCAL STORAGE SERVICE SETLISTS */
let mockSetlists = JSON.parse(localStorage.getItem("localSetlists")) || { "1": ["1", "11"], "2": ["10"], "3": [] };
function renderActiveSetlistPills() {
    const setNum = document.getElementById("setlistNumSelect").value;
    const hymns = mockSetlists[setNum] || [];
    const container = document.getElementById("activeSetlistContainer");
    if(hymns.length === 0) { container.innerHTML = "<div style='opacity:0.6;'>No items added.</div>"; return; }
    container.innerHTML = hymns.map(num => `
        <div class="setlist-pill" onclick="quickLoad('${num}')">
            🎵 Hymn ${num}
            <span class="remove-btn" onclick="event.stopPropagation(); removeHymn('${num}')">×</span>
        </div>
    `).join('');
}
function addHymnToActiveSetlist() {
    const num = document.getElementById("quickAddHymnNum").value.trim();
    const setNum = document.getElementById("setlistNumSelect").value;
    if(!num) return;
    if(!mockSetlists[setNum].includes(num)) { mockSetlists[setNum].push(num); localStorage.setItem("localSetlists", JSON.stringify(mockSetlists)); renderActiveSetlistPills(); }
    document.getElementById("quickAddHymnNum").value = "";
}
function removeHymn(num) {
    const setNum = document.getElementById("setlistNumSelect").value;
    mockSetlists[setNum] = mockSetlists[setNum].filter(n => n !== num);
    localStorage.setItem("localSetlists", JSON.stringify(mockSetlists));
    renderActiveSetlistPills();
}

/* SEARCH & RENDER WITH EXPLICIT SATB CHECK */
const searchBox = document.getElementById("searchBox");
const suggestionsBox = document.getElementById("suggestions");
let searchResultsCache = [], activeHymnPages = [], currentImageIndex = 0;

function toggleDashboard() { const d = document.getElementById("weeklyDashboard"); d.classList.toggle("open"); }
function toggleTheme() { document.body.classList.toggle("dark-mode"); }

searchBox.addEventListener("input", () => {
    let q = searchBox.value.trim().toLowerCase();
    if(!q) { suggestionsBox.style.display = "none"; return; }
    let matches = localHymnsDataset.filter(h => h.number.includes(q) || h.title.toLowerCase().includes(q));
    if(matches.length === 0) { suggestionsBox.style.display = "none"; return; }
    suggestionsBox.innerHTML = matches.slice(0, 5).map(h => `<div class="suggestion" onclick="selectSuggestion('${h.number}')"><strong>${h.number}</strong> — ${h.title}</div>`).join('');
    suggestionsBox.style.display = "flex";
});

function selectSuggestion(num) { searchBox.value = num; suggestionsBox.style.display = "none"; searchHymn(num); }
function quickLoad(num) { searchBox.value = num; searchHymn(num); }

function searchHymn(targetNum = null) {
    let q = targetNum || searchBox.value.trim();
    if(!q) return;
    suggestionsBox.style.display = "none";

    let results = localHymnsDataset.filter(h => h.number === q || h.title.toLowerCase().includes(q.toLowerCase()));
    let container = document.getElementById("results");
    
    if(results.length === 0) {
        container.innerHTML = `<div class="glass-panel">No structural records found matching "${q}".</div>`;
        document.getElementById("scoreViewer").innerHTML = "";
        return;
    }

    searchResultsCache = results;
    let html = "";

    results.forEach((hymn, index) => {
        // Build dynamic structural local path names using your uploaded folder configuration
        const folderName = `${hymn.number}-${hymn.title.replace(/[!]/g, '')}`;
        const sanitizedTitle = hymn.title.replace(/ /g, '_').replace(/[!,()]/g, '');
        
        // Define exact parts matching your visual layout files
        const partsMap = {
            "Full Ensemble SATB": `${hymn.number}-SATB-${hymn.title}.mp3`,
            "Soprano Vocal Track": `${hymn.number}-S-${hymn.title}.mp3`,
            "Alto Vocal Track": `${hymn.number}-A-${hymn.title}.mp3`,
            "Tenor Vocal Track": `${hymn.number}-T-${hymn.title}.mp3`
        };

        let audioHtml = `<div class="audio-section"><h3>🎵 SATB Split Vocal Tracks</h3><div class="audio-grid">`;
        for (const [partName, fileName] of Object.entries(partsMap)) {
            // Point the application path to look directly inside your local subfolder structures
            audioHtml += `
                <div class="audio-card">
                    <div class="voice-part">${partName}</div>
                    <audio controls preload="none">
                        <source src="/SANKEY_Learning_files/${encodeURIComponent(hymn.number + '-' + hymn.title)}/${encodeURIComponent(fileName)}" type="audio/mpeg">
                        <source src="/static/audio/${hymn.number}/${partName.split(' ')[0].toUpperCase()}.mp3" type="audio/mpeg">
                    </audio>
                </div>`;
        }
        audioHtml += `</div></div>`;

        html += `
        <div class="glass-panel" style="margin-top:20px;">
            <h2>${hymn.number} — ${hymn.title}</h2>
            <p style="opacity:0.7; font-weight:600;">Hymnal Sheet Reference Page: ${hymn.page}</p>
            <div style="display:flex; gap:10px; margin-top:15px;">
                <button onclick="showScore(${index})">🔍 View Sheet Score</button>
            </div>
            ${audioHtml}
        </div>`;
    });

    container.innerHTML = html;
    showScore(0);
}

function showScore(index) {
    let hymn = searchResultsCache[index];
    if(!hymn) return;
    activeHymnPages = [`/static/pages/Sankey_${hymn.page}.jpg`];
    currentImageIndex = 0;
    renderPage();
}

function renderPage() {
    let container = document.getElementById("scoreViewer");
    if(!activeHymnPages.length) { container.innerHTML = ""; return; }
    
    container.innerHTML = `
        <div class="glass-panel" style="margin-top:20px; text-align:center;">
            <div style="display:flex; justify-content:center; gap:10px; margin-bottom:15px;">
                <button onclick="previousPage()" ${currentImageIndex===0?'disabled':''}>← Previous</button>
                <button disabled style="background:var(--accent-color); color:white; opacity:1 !important;">Sheet View (${currentImageIndex+1}/${activeHymnPages.length})</button>
                <button onclick="nextPage()" ${currentImageIndex===activeHymnPages.length-1?'disabled':''}>Next →</button>
            </div>
            <img src="${activeHymnPages[currentImageIndex]}" onerror="handleImageError(this, '${activeHymnPages[currentImageIndex]}')">
        </div>`;
}

function handleImageError(img, url) {
    if (!img.getAttribute('data-retry') && url.endsWith('.jpg')) {
        img.setAttribute('data-retry', '1');
        img.src = url.replace('.jpg', '.png');
        return;
    }
    img.style.display = 'none';
}

function nextPage() { if(currentImageIndex < activeHymnPages.length-1) { currentImageIndex++; renderPage(); } }
function previousPage() { if(currentImageIndex > 0) { currentImageIndex--; renderPage(); } }

window.onload = () => {
    updateTimeSignature("4");
    renderActiveSetlistPills();
    document.getElementById("glossaryList").innerHTML = glossaryTerms.map(t => `<div class="term-item"><div class="term-name">${t.name}</div><div class="term-def">${t.def}</div></div>`).join('');
};
</script>
</body>
</html>
